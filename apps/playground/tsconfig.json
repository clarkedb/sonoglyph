{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  // vite.config.ts is not typechecked: it uses Node APIs (fs/url) for the
  // dsp-wasm alias and this repo has no @types/node. Vite runs it via esbuild.
  "include": ["src"]
}
