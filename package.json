{
  "name": "sonoglyph",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.1.3"
  },
  "scripts": {
    "dev": "pnpm --filter @sonoglyph/playground dev",
    "start": "pnpm dev",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "bench:bless": "sh scripts/bench/bless.sh",
    "build": "pnpm -r --if-present build",
    "build:ci": "pnpm --filter @sonoglyph/dsp-wasm build:ci && pnpm --filter @sonoglyph/playground build",
    "publish:check": "node scripts/check-publishable.ts",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "release:publish": "pnpm publish:check && pnpm build && pnpm publish -r --provenance --no-git-checks && changeset tag",
    "bootstrap": "sh scripts/bootstrap.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
