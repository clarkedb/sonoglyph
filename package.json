{
  "name": "sonoglyph",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.1.3"
  },
  "scripts": {
    "dev": "pnpm --filter @sonoglyph/playground dev",
    "start": "pnpm dev",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "build": "pnpm -r --if-present build",
    "bootstrap": "sh scripts/bootstrap.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
