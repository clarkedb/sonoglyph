{
  "name": "@sonoglyph/plugin-sdk",
  "version": "0.1.0",
  "description": "Sonoglyph plugin SDK — segmentation and debouncing helpers that turn per-frame classifiers into recognizer plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clarkedb/sonoglyph.git",
    "directory": "packages/plugin-sdk"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!dist/.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json"
  },
  "dependencies": {
    "@sonoglyph/core": "workspace:*"
  }
}
