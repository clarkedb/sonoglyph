{
  "name": "@sonoglyph/plugin-dtmf",
  "version": "0.2.0",
  "description": "DTMF recognizer plugin for Sonoglyph — the reference plugin implementation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clarkedb/sonoglyph.git",
    "directory": "plugins/dtmf"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!dist/.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json"
  },
  "dependencies": {
    "@sonoglyph/core": "workspace:*",
    "@sonoglyph/dsp": "workspace:*",
    "@sonoglyph/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@sonoglyph/testing": "workspace:*"
  }
}
